{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ntu254/Harness-Intelligence-OS/blob/main/docs/schemas/notebooklm-brief.schema.json",
  "title": "HI-OS NotebookLM Grounded Brief Artifact",
  "description": "Versioned file boundary for grounded business context produced by a NotebookLM-compatible adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "artifact_id",
    "story_id",
    "status",
    "generated_at",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "artifact_type": {
      "const": "notebooklm-brief"
    },
    "artifact_id": {
      "type": "string",
      "format": "uuid"
    },
    "story_id": {
      "type": "string",
      "pattern": "^US-[0-9]{3,}$"
    },
    "status": {
      "enum": [
        "pass",
        "fail",
        "inconclusive"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "brief": {
      "$ref": "#/$defs/brief"
    },
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "unavailable": {
      "$ref": "#/$defs/unavailable"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "pass"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "brief"
        ],
        "properties": {
          "provenance": {
            "properties": {
              "sources": {
                "minItems": 1
              }
            }
          }
        },
        "not": {
          "anyOf": [
            {
              "required": [
                "errors"
              ]
            },
            {
              "required": [
                "unavailable"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "fail"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "errors"
        ],
        "not": {
          "required": [
            "brief"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "inconclusive"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "unavailable"
        ],
        "not": {
          "required": [
            "brief"
          ]
        }
      }
    }
  ],
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "adapter",
        "adapter_version",
        "invocation_id",
        "sources"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "invocation_id": {
          "type": "string",
          "minLength": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "title",
              "uri",
              "sha256",
              "retrieved_at"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "pattern": "^SRC-[0-9]+$"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "uri": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "retrieved_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "constraints",
        "open_questions",
        "claims"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "affected_docs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "claim_id",
              "statement",
              "citations"
            ],
            "properties": {
              "claim_id": {
                "type": "string",
                "pattern": "^NL-[0-9]+$"
              },
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "citations": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "source_id",
                    "locator"
                  ],
                  "properties": {
                    "source_id": {
                      "type": "string",
                      "pattern": "^SRC-[0-9]+$"
                    },
                    "locator": {
                      "type": "string",
                      "minLength": 1
                    },
                    "quote_sha256": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "unavailable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "retryable"
      ],
      "properties": {
        "reason": {
          "enum": [
            "provider_unavailable",
            "permission_denied",
            "timeout",
            "source_unavailable",
            "insufficient_evidence"
          ]
        },
        "retryable": {
          "type": "boolean"
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
