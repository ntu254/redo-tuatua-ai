{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ntu254/Harness-Intelligence-OS/blob/main/docs/schemas/codegraph-impact.schema.json",
  "title": "HI-OS CodeGraph Impact Artifact",
  "description": "Versioned file boundary for code impact evidence produced by a CodeGraph-compatible adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "artifact_id",
    "story_id",
    "status",
    "generated_at",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "artifact_type": {
      "const": "codegraph-impact"
    },
    "artifact_id": {
      "type": "string",
      "format": "uuid"
    },
    "story_id": {
      "type": "string",
      "pattern": "^US-[0-9]{3,}$"
    },
    "status": {
      "enum": [
        "pass",
        "fail",
        "inconclusive"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "impact": {
      "$ref": "#/$defs/impact"
    },
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "unavailable": {
      "$ref": "#/$defs/unavailable"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "pass"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "impact"
        ],
        "properties": {
          "provenance": {
            "properties": {
              "inputs": {
                "minItems": 1
              }
            }
          }
        },
        "not": {
          "anyOf": [
            {
              "required": [
                "errors"
              ]
            },
            {
              "required": [
                "unavailable"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "fail"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "errors"
        ],
        "not": {
          "required": [
            "impact"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "inconclusive"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "unavailable"
        ],
        "not": {
          "required": [
            "impact"
          ]
        }
      }
    }
  ],
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "adapter",
        "adapter_version",
        "invocation_id",
        "repository",
        "revision",
        "inputs"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "invocation_id": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "uri",
              "sha256"
            ],
            "properties": {
              "uri": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "affected_files",
        "risk_flags",
        "claims"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "affected_files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "change_kind",
              "reasons"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "change_kind": {
                "enum": [
                  "direct",
                  "transitive",
                  "test",
                  "configuration",
                  "documentation"
                ]
              },
              "reasons": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "symbols": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "dependency_edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "from",
              "to",
              "kind"
            ],
            "properties": {
              "from": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "enum": [
                  "imports",
                  "calls",
                  "implements",
                  "reads",
                  "writes",
                  "configures",
                  "tests"
                ]
              }
            }
          }
        },
        "risk_flags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "auth",
              "authorization",
              "data_model",
              "audit_security",
              "external_systems",
              "public_contracts",
              "cross_platform",
              "existing_behavior",
              "weak_proof",
              "multi_domain"
            ]
          }
        },
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "claim_id",
              "statement",
              "evidence_refs"
            ],
            "properties": {
              "claim_id": {
                "type": "string",
                "pattern": "^CG-[0-9]+$"
              },
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "unavailable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "retryable"
      ],
      "properties": {
        "reason": {
          "enum": [
            "provider_unavailable",
            "permission_denied",
            "timeout",
            "repository_unavailable",
            "insufficient_evidence"
          ]
        },
        "retryable": {
          "type": "boolean"
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
